@model TeploenergetikaKursovaya.Models.CalcResultsViewModel
@{
    ViewData["Title"] = "Результаты расчета";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h2 class="text-center">Результаты расчета</h2>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <h4>Средняя температура на участке: @Model.averageTemperature.ToString("F2") °C</h4>
            </div>
            <div class="text-center mt-4">
                <a href="@Url.Action("Index")" class="btn btn-primary">Сделать новый расчет</a>
            </div>
        </div>
    </div>
</div>