@using System.Globalization
@using Newtonsoft.Json
@using TeploenergetikaKursovaya.Models
@model TeploenergetikaKursovaya.Models.CalcPageViewModel
@{
    ViewData["Title"] = "Итоговый отчет";

    double cumulativeLoss = 0;
    var hasGeometricPressure = Math.Abs(Model.Summary.GeometricLoss) > 0.0001;
    var rows = Model.Results.Select(result =>
    {
        var blockPressureDrop = result.PressureDropFriction + result.PressureDropLocal;
        cumulativeLoss += blockPressureDrop;
        return new
        {
            Result = result,
            BlockPressureDrop = blockPressureDrop,
            CumulativeLoss = cumulativeLoss
        };
    }).ToList();

    var totalLoss = Math.Abs(Model.Summary.TotalPressureDrop) < 0.0001 ? 1 : Math.Abs(Model.Summary.TotalPressureDrop);
    var frictionShare = Math.Abs(Model.Summary.FrictionLoss) / totalLoss * 100;
    var localShare = Math.Abs(Model.Summary.LocalLoss) / totalLoss * 100;
    var geometricShare = Math.Abs(Model.Summary.GeometricLoss) / totalLoss * 100;

    var shareRows = new[]
    {
        new { Label = "Трение", Value = Math.Abs(Model.Summary.FrictionLoss), Share = frictionShare, Css = "friction", Color = "#a34f3d" },
        new { Label = "Местные сопротивления", Value = Math.Abs(Model.Summary.LocalLoss), Share = localShare, Css = "local", Color = "#d8a661" },
        new { Label = "Геометрическая составляющая", Value = Math.Abs(Model.Summary.GeometricLoss), Share = geometricShare, Css = "geometric", Color = "#507f82" }
    };

    const double chartWidth = 560;
    const double chartHeight = 240;
    const double chartPaddingLeft = 42;
    const double chartPaddingRight = 14;
    const double chartPaddingTop = 14;
    const double chartPaddingBottom = 34;

    var plotWidth = chartWidth - chartPaddingLeft - chartPaddingRight;
    var plotHeight = chartHeight - chartPaddingTop - chartPaddingBottom;
    var sectionCount = Math.Max(rows.Count, 1);
    var barStepWidth = plotWidth / sectionCount;
    var barWidth = Math.Max(24, Math.Min(56, barStepWidth * 0.58));
    var cumulativePointCount = Math.Max(rows.Count + (hasGeometricPressure ? 1 : 0), 1);
    var cumulativeStepWidth = plotWidth / cumulativePointCount;
    var maxSectionLoss = Math.Max(rows.Count == 0 ? 0 : rows.Max(row => Math.Abs(row.BlockPressureDrop)), 1);
    var maxCumulativeLoss = Math.Max(
        Math.Max(rows.Count == 0 ? 0 : rows.Max(row => Math.Abs(row.CumulativeLoss)), Math.Abs(Model.Summary.TotalPressureDrop)),
        1);

    string ToInvariant(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);
    double Normalize(double value, double max) => max <= 0 ? 0 : Math.Abs(value) / max;
    string FormatPa(double value) => $"{value.ToString("F1", CultureInfo.InvariantCulture)} Па";
    string GetBlockLabel(CalcResultsViewModel item) =>
        string.IsNullOrWhiteSpace(item.SectionName)
            ? $"Блок {item.SectionNumber}"
            : $"Блок {item.SectionNumber}: {item.SectionName}";

    string BuildBlockLossTooltip(CalcResultsViewModel item, double blockPressureDrop) =>
        $"{GetBlockLabel(item)}\nТип: {item.SectionType}\nОбщие потери блока: {FormatPa(blockPressureDrop)}\nТрение: {FormatPa(item.PressureDropFriction)}\nМестное сопротивление: {FormatPa(item.PressureDropLocal)}\nКМС ζ: {item.Zeta.ToString("F3", CultureInfo.InvariantCulture)}";

    string BuildCumulativeTooltip(CalcResultsViewModel item, double cumulativeValue) =>
        $"{GetBlockLabel(item)}\nНакопленные потери после блока: {FormatPa(cumulativeValue)}\nПотери этого блока: {FormatPa(item.PressureDropFriction + item.PressureDropLocal)}";

    string BuildGeometricTooltip() =>
        $"Геометрическое давление трассы\nЗначение: {FormatPa(Model.Summary.GeometricLoss)}\nИтоговые потери после учета геометрии: {FormatPa(Model.Summary.TotalPressureDrop)}";

    string GetBarX(int index)
    {
        var centerX = chartPaddingLeft + barStepWidth * index + barStepWidth / 2.0;
        return ToInvariant(centerX - barWidth / 2.0);
    }

    string GetBarHeight(double value) => ToInvariant(Normalize(value, maxSectionLoss) * plotHeight);
    string GetBarY(double value)
    {
        var height = Normalize(value, maxSectionLoss) * plotHeight;
        return ToInvariant(chartPaddingTop + plotHeight - height);
    }

    string GetCumulativePoint(int index, double value)
    {
        var x = chartPaddingLeft + (cumulativePointCount == 1 ? plotWidth / 2.0 : cumulativeStepWidth * index + cumulativeStepWidth / 2.0);
        var y = chartPaddingTop + plotHeight - Normalize(value, maxCumulativeLoss) * plotHeight;
        return $"{ToInvariant(x)},{ToInvariant(y)}";
    }

    var cumulativePoints = rows
        .Select((row, index) => GetCumulativePoint(index, row.CumulativeLoss))
        .ToList();

    if (hasGeometricPressure)
    {
        cumulativePoints.Add(GetCumulativePoint(rows.Count, Model.Summary.TotalPressureDrop));
    }

    var cumulativePolyline = cumulativePoints.Count == 0
        ? string.Empty
        : string.Join(" ", cumulativePoints);

    string DescribeSectionKind(string kind) =>
        SectionKinds.Normalize(kind) switch
        {
            SectionKinds.Straight => "Прямой участок",
            SectionKinds.Bend => "Поворот",
            SectionKinds.Contraction => "Сужение",
            SectionKinds.Expansion => "Расширение",
            SectionKinds.LocalResistance => "Местное сопротивление",
            _ => "Элемент"
        };

    string DescribeCrossSectionShape(string? shape) =>
        SectionShapeKinds.Translate(shape);

    string GetSizePrefix(string? shape, bool outlet = false)
    {
        var normalizedShape = SectionShapeKinds.Normalize(shape);
        return normalizedShape == SectionShapeKinds.Rectangle
            ? (outlet ? "a×b вых" : "a×b вх")
            : (outlet ? "Dвых" : "Dвх");
    }

    string FormatSectionSize(string? shape, double? sizeA, double? sizeB)
    {
        if (!sizeA.HasValue)
        {
            return "—";
        }

        return SectionShapeKinds.Normalize(shape) == SectionShapeKinds.Rectangle
            ? $"{sizeA.Value:F3} × {(sizeB ?? sizeA).Value:F3}"
            : sizeA.Value.ToString("F3");
    }

    string UnitLabel(string? unit) =>
        unit switch
        {
            "k" => "K",
            "m3h" => "м³/ч",
            "mm" => "мм",
            "percent" => "%",
            "cTotal" => "°C всего",
            "cPerM" => "°C/м",
            "rad" => "рад",
            "deg" => "°",
            "fraction" => "доля",
            _ => unit == "m3s" ? "м³/с" : unit == "m" ? "м" : "°C"
        };

    double ConvertFromBase(double value, string baseUnit, string? displayUnit) =>
        (baseUnit, displayUnit) switch
        {
            ("c", "k") => value + 273.15,
            ("m3s", "m3h") => value * 3600,
            ("m", "mm") => value * 1000,
            ("deg", "rad") => value * Math.PI / 180.0,
            ("fraction", "percent") => value * 100,
            _ => value
        };

    string FormatDisplay(double? value, string baseUnit, string? displayUnit, int digits)
    {
        if (!value.HasValue)
        {
            return "—";
        }

        var converted = ConvertFromBase(value.Value, baseUnit, displayUnit);
        return $"{converted.ToString($"F{digits}")} {UnitLabel(displayUnit)}";
    }

    string FormatSectionDimension(double? value, string? unit) =>
        FormatDisplay(value, "m", unit, unit == "mm" ? 1 : 3);

    string FormatSectionSizeWithUnits(string? shape, double? sizeA, double? sizeB, string? unitA, string? unitB)
    {
        if (!sizeA.HasValue)
        {
            return "—";
        }

        if (SectionShapeKinds.Normalize(shape) == SectionShapeKinds.Rectangle)
        {
            return $"{FormatSectionDimension(sizeA, unitA)} × {FormatSectionDimension(sizeB ?? sizeA, unitB)}";
        }

        return FormatSectionDimension(sizeA, unitA);
    }

    string FormatHeatLoss(SectionInput section)
    {
        var perMeter = section.TemperatureLossPerMeter ?? Model.Input.TemperatureLossPerMeter;
        if (section.TemperatureLossUnit == "cTotal")
        {
            var total = perMeter * (section.Length ?? 0);
            return $"{total:F2} °C всего";
        }

        return $"{perMeter:F3} °C/м";
    }

    string FormatSmartNumber(double value, int maxDigits = 4)
    {
        var pattern = maxDigits <= 0 ? "0" : $"0.{new string('#', maxDigits)}";
        return value.ToString(pattern);
    }

    string FormatBlockMaterial(CalcResultsViewModel result)
    {
        if (string.IsNullOrWhiteSpace(result.MaterialType))
        {
            return "—";
        }

        var condition = string.IsNullOrWhiteSpace(result.SurfaceCondition)
            ? "Справочное значение"
            : result.SurfaceCondition.Trim();

        return $"{result.MaterialType.Trim()} / {condition}";
    }

    string FormatBlockRoughness(CalcResultsViewModel result) =>
        $"Kэ = {FormatSmartNumber(result.Roughness)} мм";

    string DescribeRoughnessSource(SectionInput? section)
    {
        if (section is null)
        {
            return "Фактическое значение расчета";
        }

        var materialSource = section.UseIndividualMaterial
            ? "индивидуальный материал блока"
            : "материал трассы";

        var roughnessSource = section.UseCustomRoughness
            ? "собственная шероховатость"
            : "табличная шероховатость";

        return $"{materialSource}, {roughnessSource}";
    }

    string DescribeLocalResistanceUnderType(SectionInput? section)
    {
        if (section is null || SectionKinds.Normalize(section.SectionKind) != SectionKinds.LocalResistance)
        {
            return string.Empty;
        }

        if (section.UseCustomLRC && section.CustomLRC.HasValue)
        {
            return $"КМС задан вручную: ζ = {section.CustomLRC.Value:F3}";
        }

        return string.IsNullOrWhiteSpace(section.LocalResistanceType)
            ? "Тип местного сопротивления не выбран"
            : section.LocalResistanceType.Trim();
    }

    List<KeyValuePair<string, string>> BuildCombinedParameterRows(SectionInput? section, CalcResultsViewModel result)
    {
        var values = new List<KeyValuePair<string, string>>();

        if (section is null)
        {
            values.Add(new("Форма", result.CrossSectionShape));
            values.Add(new("Размер", FormatSectionSize(result.CrossSectionShape, result.Diameter, result.DiameterB)));
            values.Add(new("Dэкв", $"{result.EquivalentDiameter:F3} м"));
            values.Add(new("Длина", $"{result.Length:F3} м"));
            return values;
        }

        var kind = SectionKinds.Normalize(section.SectionKind);
        var shape = SectionShapeKinds.Normalize(section.CrossSectionShape);
        var outletShape = SectionShapeKinds.Normalize(section.OutletCrossSectionShape);
        var shapeLabel = DescribeCrossSectionShape(shape);

        if (!string.Equals(result.CrossSectionShape, result.OutletCrossSectionShape, StringComparison.Ordinal))
        {
            shapeLabel = $"{result.CrossSectionShape} → {result.OutletCrossSectionShape}";
        }

        values.Add(new("Форма", shapeLabel));

        if (section.Length.HasValue &&
            !(kind == SectionKinds.LocalResistance && SectionInput.IsStraightPipeEntrance(section.LocalResistanceType)))
        {
            values.Add(new("Длина", FormatSectionDimension(section.Length, section.LengthUnit)));
        }

        values.Add(new("ΔT", FormatHeatLoss(section)));

        if (section.Diameter.HasValue)
        {
            values.Add(new(GetSizePrefix(shape), FormatSectionSizeWithUnits(shape, section.Diameter, section.DiameterB, section.DiameterUnit, section.DiameterBUnit)));
        }

        if ((kind == SectionKinds.Contraction || kind == SectionKinds.Expansion ||
             !string.Equals(result.CrossSectionShape, result.OutletCrossSectionShape, StringComparison.Ordinal) ||
             Math.Abs(result.OutletDiameter - result.Diameter) > 0.0001 ||
             Math.Abs(result.OutletDiameterB - result.DiameterB) > 0.0001) &&
            section.OutletDiameter.HasValue)
        {
            values.Add(new(GetSizePrefix(outletShape, outlet: true), FormatSectionSizeWithUnits(outletShape, section.OutletDiameter, section.OutletDiameterB, section.OutletDiameterUnit, section.OutletDiameterBUnit)));
        }

        if (kind == SectionKinds.Bend && section.TurnAngle.HasValue)
        {
            values.Add(new("Угол", FormatDisplay(section.TurnAngle, "deg", section.TurnAngleUnit, section.TurnAngleUnit == "rad" ? 2 : 0)));
        }

        if (kind == SectionKinds.LocalResistance && section.LocalResistanceParamX.HasValue && section.LocalResistanceParamY.HasValue)
        {
            if (SectionInput.IsStraightPipeEntrance(section.LocalResistanceType))
            {
                values.Add(new("b", FormatSectionDimension(section.LocalResistanceParamX, "m")));
                values.Add(new("δ₁", FormatSectionDimension(section.LocalResistanceParamY, "m")));

                if (section.Diameter.HasValue && section.Diameter.Value > 0)
                {
                    values.Add(new("b/Dг", (section.LocalResistanceParamX.Value / section.Diameter.Value).ToString("F3")));
                    values.Add(new("δ₁/Dг", (section.LocalResistanceParamY.Value / section.Diameter.Value).ToString("F3")));
                }
            }
            else
            {
                values.Add(new("α", $"{section.LocalResistanceParamX.Value:F0}°"));
                values.Add(new("l/d₀", section.LocalResistanceParamY.Value.ToString("F3")));
            }
        }

        return values;
    }

    string DescribeRouteParameters(SectionInput section)
    {
        var parts = new List<string>();
        var kind = SectionKinds.Normalize(section.SectionKind);
        var shape = SectionShapeKinds.Normalize(section.CrossSectionShape);

        parts.Add($"Форма {DescribeCrossSectionShape(shape).ToLowerInvariant()}");

        if (section.Diameter.HasValue)
        {
            parts.Add($"{GetSizePrefix(shape)} {FormatSectionSizeWithUnits(shape, section.Diameter, section.DiameterB, section.DiameterUnit, section.DiameterBUnit)}");
        }

        if ((kind == SectionKinds.Contraction || kind == SectionKinds.Expansion) && section.OutletDiameter.HasValue)
        {
            var outletShape = SectionShapeKinds.Normalize(section.OutletCrossSectionShape);
            parts.Add($"{GetSizePrefix(outletShape, outlet: true)} {FormatSectionSizeWithUnits(outletShape, section.OutletDiameter, section.OutletDiameterB, section.OutletDiameterUnit, section.OutletDiameterBUnit)}");
        }

        if (kind == SectionKinds.Straight && section.Length.HasValue)
        {
            parts.Add($"L {FormatSectionDimension(section.Length, section.LengthUnit)}");
        }

        parts.Add($"ΔT {FormatHeatLoss(section)}");

        if (kind == SectionKinds.Bend && section.TurnAngle.HasValue)
        {
            parts.Add($"Угол {section.TurnAngle.Value:F0}°");
        }

        if (kind == SectionKinds.LocalResistance)
        {
            if (section.UseCustomLRC && section.CustomLRC.HasValue)
            {
                parts.Add($"ζ {section.CustomLRC.Value:F3}");
            }
            else if (!string.IsNullOrWhiteSpace(section.LocalResistanceType))
            {
                parts.Add(section.LocalResistanceType!);
                if (section.LocalResistanceParamX.HasValue && section.LocalResistanceParamY.HasValue)
                {
                    if (SectionInput.IsStraightPipeEntrance(section.LocalResistanceType))
                    {
                        var ratioB = section.Diameter.HasValue && section.Diameter.Value > 0
                            ? section.LocalResistanceParamX.Value / section.Diameter.Value
                            : (double?)null;
                        var ratioSigma = section.Diameter.HasValue && section.Diameter.Value > 0
                            ? section.LocalResistanceParamY.Value / section.Diameter.Value
                            : (double?)null;
                        parts.Add($"b {FormatSectionDimension(section.LocalResistanceParamX, "m")}; δ₁ {FormatSectionDimension(section.LocalResistanceParamY, "m")}");
                        if (ratioB.HasValue && ratioSigma.HasValue)
                        {
                            parts.Add($"b/Dг {ratioB.Value:F3}; δ₁/Dг {ratioSigma.Value:F3}");
                        }
                    }
                    else
                    {
                        parts.Add($"α {section.LocalResistanceParamX.Value:F0}; l/d₀ {section.LocalResistanceParamY.Value:F3}");
                    }
                }
            }
        }

        return parts.Count == 0 ? "Параметры будут уточнены в таблице ниже." : string.Join(" · ", parts);
    }
}

<div class="report-shell print-report">
    <section class="report-hero">
        <div>
            <p class="eyebrow">Итоговый аналитический отчет</p>
            <h1>Расчет дымовой трассы завершен</h1>
            <p class="hero-text">
                В отчете собраны исходные параметры, маршрут пользователя, данные по каждому блоку,
                сводные показатели системы и рекомендации по снижению потерь давления.
            </p>
        </div>
        <div class="report-actions">
            @if (Model.SavedCalculationId.HasValue)
            {
                <a href="@Url.Action("Calc", new { calculationId = Model.SavedCalculationId })" class="btn btn-outline-primary">Изменить расчет</a>
                <a href="@Url.Action("Calc", new { repeatCalculationId = Model.SavedCalculationId })" class="btn btn-outline-primary">Повторить расчет</a>
            }
            else
            {
                <a href="@Url.Action("Calc")" class="btn btn-outline-primary">Вернуться в редактор</a>
            }
            @if (!Model.IsAuthenticated)
            {
                <button type="button" class="btn btn-outline-primary" id="saveGuestCalculationBtn">Сохранить расчет</button>
            }
            <button type="button" class="btn btn-primary" onclick="window.print()">Печать отчета</button>
        </div>
    </section>

    <section class="report-grid">
        <div class="panel-block">
            <div class="panel-head">
                <div>
                    <p class="panel-kicker">Исходные параметры</p>
                    <h2>Общие данные расчета</h2>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table modern-table report-data-table">
                    <tbody>
                        <tr>
                            <th>Начальная температура газа</th>
                            <td>@FormatDisplay(Model.Input.TgasInitial, "c", Model.Input.TgasInitialUnit, 1)</td>
                            <th>Расход газа (в рабочем состоянии)</th>
                            <td>@FormatDisplay(Model.Input.GasFlow, "m3s", Model.Input.GasFlowUnit, Model.Input.GasFlowUnit == "m3h" ? 1 : 2)</td>
                        </tr>
                        <tr>
                            <th>Базовый материал</th>
                            <td>@Model.Input.MaterialType</td>
                            <th>Состояние поверхности</th>
                            <td>@Model.Input.SurfaceCondition</td>
                        </tr>
                        <tr>
                            <th>Шероховатость</th>
                            <td>
                                @(Model.Input.UseCustomRoughness && Model.Input.CustomRoughness.HasValue
                                    ? FormatDisplay(Model.Input.CustomRoughness.Value, "m", Model.Input.CustomRoughnessUnit, Model.Input.CustomRoughnessUnit == "mm" ? 3 : 6)
                                    : "По табличным данным")
                            </td>
                            <th>Суммарный перепад высоты</th>
                            <td>@Model.Summary.TotalHeightChange.ToString("F2") м</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="analysis-card mt-3">
                <h3>Состав дымовых газов</h3>
                <p>
                    N₂: <strong>@FormatDisplay(Model.Input.Y_N2, "fraction", Model.Input.Y_N2Unit, Model.Input.Y_N2Unit == "percent" ? 1 : 3)</strong>,
                    O₂: <strong>@FormatDisplay(Model.Input.Y_O2, "fraction", Model.Input.Y_O2Unit, Model.Input.Y_O2Unit == "percent" ? 1 : 3)</strong>,
                    CO₂: <strong>@FormatDisplay(Model.Input.Y_CO2, "fraction", Model.Input.Y_CO2Unit, Model.Input.Y_CO2Unit == "percent" ? 1 : 3)</strong>,
                    H₂O: <strong>@FormatDisplay(Model.Input.Y_H2O, "fraction", Model.Input.Y_H2OUnit, Model.Input.Y_H2OUnit == "percent" ? 1 : 3)</strong>.
                </p>
            </div>
        </div>

        <div class="panel-block">
            <div class="panel-head">
                <div>
                    <p class="panel-kicker">Сводные показатели</p>
                    <h2>Ключевые параметры системы</h2>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table modern-table report-data-table">
                    <tbody>
                        <tr>
                            <th>Суммарные потери давления</th>
                            <td>@Model.Summary.TotalPressureDrop.ToString("F1") Па</td>
                            <th>Потери на трение</th>
                            <td>@Model.Summary.FrictionLoss.ToString("F1") Па</td>
                        </tr>
                        <tr>
                            <th>Местные сопротивления</th>
                            <td>@Model.Summary.LocalLoss.ToString("F1") Па</td>
                            <th>Геометрическая составляющая</th>
                            <td>@Model.Summary.GeometricLoss.ToString("F1") Па</td>
                        </tr>
                        <tr>
                            <th>Протяженность трассы</th>
                            <td>@Model.Summary.TotalRouteLength.ToString("F2") м</td>
                            <th>Максимальная скорость газа</th>
                            <td>@Model.Summary.MaxVelocity.ToString("F2") м/с</td>
                        </tr>
                        <tr>
                            <th>Критический элемент</th>
                            <td>@Model.Summary.CriticalSectionName</td>
                            <th>Учет геометрического давления</th>
                            <td>@(Model.Input.UseGeometricPressure ? "Включен" : "Не включен")</td>
                        </tr>
                        <tr>
                            <th>Оценка эффективности</th>
                            <td colspan="3">@Model.Summary.EfficiencyLabel</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    @if (Model.Input.UseGeometricPressure)
    {
        <section class="panel-block geometry-pressure-panel">
            <div class="panel-head">
                <div>
                    <p class="panel-kicker">Учет геометрического давления</p>
                    <h2>Результаты блока</h2>
                </div>
            </div>

            <div class="geometry-pressure-grid">
                <div class="geometry-pressure-card">
                    <span>Температура наружного воздуха</span>
                    <strong>@FormatDisplay(Model.Input.AmbientAirTemperature, "c", Model.Input.AmbientAirTemperatureUnit, 1)</strong>
                    <p>Значение использовано для расчета плотности воздуха.</p>
                </div>
                <div class="geometry-pressure-card">
                    <span>Плотность наружного воздуха</span>
                    <strong>@Model.Summary.AmbientAirDensity.ToString("F3") кг/м³</strong>
                    <p>При заданной температуре и давлении 101.325 кПа.</p>
                </div>
                <div class="geometry-pressure-card">
                    <span>Нивелирная разность высот</span>
                    <strong>@Model.Summary.TotalHeightChange.ToString("F2") м</strong>
                    <p>Положительное значение соответствует конечной точке выше начальной.</p>
                </div>
                <div class="geometry-pressure-card">
                    <span>ΔPгеом</span>
                    <strong>@Model.Summary.GeometricLoss.ToString("F1") Па</strong>
                    <p>Это значение входит в суммарные потери давления.</p>
                </div>
            </div>

            <div class="geometry-pressure-note">
                @if (Math.Abs(Model.Summary.TotalHeightChange) < 0.0001)
                {
                    <p>H = 0: конечная и начальная отметки совпадают, геометрическое давление не учитывается.</p>
                    <p>Подъемы и спуски на одинаковую высоту взаимно компенсируются.</p>
                }
                else if (Model.Summary.TotalHeightChange > 0)
                {
                    <p>H = @Model.Summary.TotalHeightChange.ToString("F2") м: конечная точка выше начальной.</p>
                    <p>Горячие газы движутся вверх, поэтому ΔPгеом идет со знаком минус и уменьшает общее сопротивление.</p>
                }
                else
                {
                    <p>H = @Model.Summary.TotalHeightChange.ToString("F2") м: конечная точка ниже начальной.</p>
                    <p>Горячие газы движутся вниз, поэтому ΔPгеом идет со знаком плюс и увеличивает общее сопротивление.</p>
                }
            </div>
        </section>
    }

    <section class="panel-block">
        <div class="panel-head">
            <div>
                <p class="panel-kicker">Графики</p>
                <h2>Сводные показатели по трассе</h2>
            </div>
        </div>

        <div class="chart-grid">
            <article class="chart-card">
                <h3>Структура потерь давления</h3>
                <div class="loss-bar">
                    @foreach (var item in shareRows)
                    {
                        <span class="loss-segment @item.Css"
                              style="width:@item.Share.ToString("F2", CultureInfo.InvariantCulture)%"
                              title="@($"{item.Label}: {item.Value.ToString("F1", CultureInfo.InvariantCulture)} Па ({item.Share.ToString("F1", CultureInfo.InvariantCulture)}%)")"></span>
                    }
                </div>
                <div class="chart-legend">
                    @foreach (var item in shareRows)
                    {
                        <div>
                            <span class="legend-dot @item.Css"></span>
                            @item.Label: @item.Value.ToString("F1") Па (@item.Share.ToString("F1")%)
                        </div>
                    }
                </div>
            </article>

            <article class="chart-card">
                <h3>Потери давления по блокам</h3>
                @if (rows.Count == 0)
                {
                    <p class="muted-text">График появится после расчета хотя бы одного блока.</p>
                }
                else
                {
                    <svg class="chart-svg" viewBox="0 0 560 240" role="img" aria-label="График потерь давления по блокам">
                        <line x1="@ToInvariant(chartPaddingLeft)" y1="@ToInvariant(chartPaddingTop)" x2="@ToInvariant(chartPaddingLeft)" y2="@ToInvariant(chartPaddingTop + plotHeight)" />
                        <line x1="@ToInvariant(chartPaddingLeft)" y1="@ToInvariant(chartPaddingTop + plotHeight)" x2="@ToInvariant(chartPaddingLeft + plotWidth)" y2="@ToInvariant(chartPaddingTop + plotHeight)" />
                        @for (int i = 0; i < rows.Count; i++)
                        {
                            var item = rows[i].Result;
                            var blockPressureDrop = rows[i].BlockPressureDrop;
                            <rect class="chart-bar"
                                  x="@GetBarX(i)"
                                  y="@GetBarY(blockPressureDrop)"
                                  width="@ToInvariant(barWidth)"
                                  height="@GetBarHeight(blockPressureDrop)"
                                  rx="8"
                                  fill="#8f3d2e"
                                  tabindex="0">
                                <title>@BuildBlockLossTooltip(item, blockPressureDrop)</title>
                            </rect>
                            @Html.Raw($"<text x=\"{ToInvariant(chartPaddingLeft + barStepWidth * i + barStepWidth / 2.0)}\" y=\"{ToInvariant(chartPaddingTop + plotHeight + 18)}\" text-anchor=\"middle\">{item.SectionNumber}</text>")
                        }
                        @Html.Raw($"<text x=\"{ToInvariant(chartPaddingLeft)}\" y=\"{ToInvariant(chartPaddingTop - 2)}\">Па</text>")
                    </svg>
                    <p class="chart-caption">По горизонтали указаны номера блоков. Наведите на столбец, чтобы увидеть название блока, потери и КМС.</p>
                }
            </article>

            <article class="chart-card">
                <h3>Накопленные потери вдоль маршрута</h3>
                @if (rows.Count == 0)
                {
                    <p class="muted-text">График появится после расчета хотя бы одного блока.</p>
                }
                else
                {
                    <svg class="chart-svg" viewBox="0 0 560 240" role="img" aria-label="График накопленных потерь">
                        <line x1="@ToInvariant(chartPaddingLeft)" y1="@ToInvariant(chartPaddingTop)" x2="@ToInvariant(chartPaddingLeft)" y2="@ToInvariant(chartPaddingTop + plotHeight)" />
                        <line x1="@ToInvariant(chartPaddingLeft)" y1="@ToInvariant(chartPaddingTop + plotHeight)" x2="@ToInvariant(chartPaddingLeft + plotWidth)" y2="@ToInvariant(chartPaddingTop + plotHeight)" />
                        <polyline points="@cumulativePolyline"
                                  fill="none"
                                  stroke="#507f82"
                                  stroke-width="4"
                                  stroke-linecap="round"
                                  stroke-linejoin="round" />
                        @for (int i = 0; i < rows.Count; i++)
                        {
                            var point = GetCumulativePoint(i, rows[i].CumulativeLoss).Split(',');
                            <circle class="chart-point"
                                    cx="@point[0]"
                                    cy="@point[1]"
                                    r="6"
                                    fill="#507f82"
                                    tabindex="0">
                                <title>@BuildCumulativeTooltip(rows[i].Result, rows[i].CumulativeLoss)</title>
                            </circle>
                            @Html.Raw($"<text x=\"{ToInvariant(chartPaddingLeft + cumulativeStepWidth * i + cumulativeStepWidth / 2.0)}\" y=\"{ToInvariant(chartPaddingTop + plotHeight + 18)}\" text-anchor=\"middle\">{rows[i].Result.SectionNumber}</text>")
                        }
                        @if (hasGeometricPressure)
                        {
                            var geometricPoint = GetCumulativePoint(rows.Count, Model.Summary.TotalPressureDrop).Split(',');
                            <circle class="chart-point chart-point-geometric"
                                    cx="@geometricPoint[0]"
                                    cy="@geometricPoint[1]"
                                    r="6"
                                    fill="#d8a661"
                                    tabindex="0">
                                <title>@BuildGeometricTooltip()</title>
                            </circle>
                            @Html.Raw($"<text x=\"{ToInvariant(chartPaddingLeft + cumulativeStepWidth * rows.Count + cumulativeStepWidth / 2.0)}\" y=\"{ToInvariant(chartPaddingTop + plotHeight + 18)}\" text-anchor=\"middle\">Геом.</text>")
                        }
                        @Html.Raw($"<text x=\"{ToInvariant(chartPaddingLeft)}\" y=\"{ToInvariant(chartPaddingTop - 2)}\">Па</text>")
                    </svg>
                    <p class="chart-caption">Линия показывает накопленные потери после каждого блока. Если геометрическое давление включено, оно добавляется отдельной точкой «Геом.».</p>
                }
            </article>
        </div>
    </section>

    <section class="panel-block">
        <div class="panel-head">
            <div>
                <p class="panel-kicker">Маршрут пользователя</p>
                <h2>Построенная схема дымовой трассы</h2>
            </div>
        </div>

        <div class="route-visual-strip">
            @for (int i = 0; i < Model.Input.Sections.Count; i++)
            {
                var item = Model.Input.Sections[i];
                <div class="route-visual-card">
                    <span class="route-visual-card__step">@(i + 1)</span>
                    <strong>@item.DisplayTitle(i + 1)</strong>
                    <small>@DescribeSectionKind(item.SectionKind)</small>
                    <p>@DescribeRouteParameters(item)</p>
                </div>
            }
        </div>
    </section>

    <section class="panel-block">
        <div class="panel-head">
            <div>
                <p class="panel-kicker">Единая таблица</p>
                <h2>Параметры и результаты расчета по блокам</h2>
            </div>
        </div>

        <div class="table-responsive results-detail-scroll">
            <table class="table modern-table print-table results-detail-table">
                <colgroup>
                    <col class="col-number" />
                    <col class="col-element" />
                    <col class="col-type" />
                    <col class="col-parameters" />
                    <col class="col-material" />
                    <col class="col-calculation" />
                    <col class="col-losses" />
                </colgroup>
                <thead>
                    <tr>
                        <th>№</th>
                        <th class="column-element">Элемент</th>
                        <th class="column-type">Тип</th>
                        <th>Введенные параметры</th>
                        <th>Материал / шероховатость</th>
                        <th>Расчетные значения</th>
                        <th>Потери, Па</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        var item = row.Result;
                        var inputSection = Model.Input.Sections.ElementAtOrDefault(item.SectionNumber - 1);
                        var parameterRows = BuildCombinedParameterRows(inputSection, item);
                        var localResistanceSubtitle = DescribeLocalResistanceUnderType(inputSection);
                        <tr>
                            <td class="result-number">@item.SectionNumber</td>
                            <td class="column-element result-name-cell">@item.SectionName</td>
                            <td class="column-type result-type-cell">
                                <strong>@item.SectionType</strong>
                                @if (!string.IsNullOrWhiteSpace(localResistanceSubtitle))
                                {
                                    <span>@localResistanceSubtitle</span>
                                }
                            </td>
                            <td class="result-parameters-cell">
                                <div class="result-parameter-list">
                                    @foreach (var parameter in parameterRows)
                                    {
                                        <span class="result-parameter">
                                            <span>@parameter.Key</span>
                                            <strong>@parameter.Value</strong>
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="result-material-cell">
                                <div class="result-cell-primary">@FormatBlockMaterial(item)</div>
                                <div class="result-cell-meta">@DescribeRoughnessSource(inputSection)</div>
                                <div class="result-cell-meta">
                                    <span>Шероховатость:</span>
                                    <strong>@FormatBlockRoughness(item)</strong>
                                </div>
                            </td>
                            <td class="result-calc-cell">
                                <div class="compact-metric-grid result-calc-grid">
                                    <span class="compact-metric">
                                        <span>T</span>
                                        <strong>@item.AverageTemperature.ToString("F1")</strong>
                                        <small>°C</small>
                                    </span>
                                    <span class="compact-metric">
                                        <span>w</span>
                                        <strong>@item.FlowVelocity.ToString("F2")</strong>
                                        <small>м/с</small>
                                    </span>
                                    <span class="compact-metric">
                                        <span>Re</span>
                                        <strong>@item.Re.ToString("F0")</strong>
                                    </span>
                                    <span class="compact-metric">
                                        <span>λ</span>
                                        <strong>@item.Lambda.ToString("F4")</strong>
                                    </span>
                                    <span class="compact-metric compact-metric-wide">
                                        <span>ζ</span>
                                        <strong>@item.Zeta.ToString("F3")</strong>
                                    </span>
                                </div>
                            </td>
                            <td class="result-loss-cell">
                                <div class="loss-metric-grid">
                                    <span class="loss-metric">
                                        <span>ΔPтр</span>
                                        <strong>@item.PressureDropFriction.ToString("F1")</strong>
                                    </span>
                                    <span class="loss-metric">
                                        <span>ΔPмс</span>
                                        <strong>@item.PressureDropLocal.ToString("F1")</strong>
                                    </span>
                                    <span class="loss-metric">
                                        <span>ΔPгеом</span>
                                        <strong>@(Math.Abs(item.GeometricPressureDrop) > 0.0001 ? item.GeometricPressureDrop.ToString("F1") : "—")</strong>
                                    </span>
                                    <span class="loss-metric is-total">
                                        <span>ΔP блока</span>
                                        <strong>@row.BlockPressureDrop.ToString("F1")</strong>
                                    </span>
                                    <span class="loss-metric is-sum">
                                        <span>ΣΔP</span>
                                        <strong>@row.CumulativeLoss.ToString("F1")</strong>
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (hasGeometricPressure)
                    {
                        <tr class="geometric-summary-row">
                            <td class="result-number">—</td>
                            <td class="column-element result-name-cell" colspan="5">
                                <strong>Геометрическое давление трассы</strong>
                                <span class="result-cell-meta geometric-note-cell">
                                    ΣΔH = @Model.Summary.TotalHeightChange.ToString("F2") м. Итоговая поправка учитывается в общем результате трассы.
                                </span>
                            </td>
                            <td class="result-loss-cell">
                                <div class="loss-metric-grid">
                                    <span class="loss-metric">
                                        <span>ΔPгеом</span>
                                        <strong>@Model.Summary.GeometricLoss.ToString("F1")</strong>
                                    </span>
                                    <span class="loss-metric is-total">
                                        <span>Итог</span>
                                        <strong>@Model.Summary.TotalPressureDrop.ToString("F1")</strong>
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="report-grid">
        <div class="panel-block recommendations-panel" data-recommendations-panel>
            <div class="panel-head">
                <div>
                    <p class="panel-kicker">Рекомендации</p>
                    <h2>Пути снижения потерь давления</h2>
                </div>
                <button type="button"
                        class="btn btn-outline-primary btn-sm recommendation-toggle"
                        data-recommendations-toggle
                        aria-expanded="true">
                    Скрыть
                </button>
            </div>

            <div class="recommendation-list" data-recommendations-content>
                @if (Model.Recommendations.Count == 0)
                {
                    <p class="muted-text">Критических замечаний не выявлено. Трасса выглядит устойчивой для выбранных параметров.</p>
                }
                else
                {
                    foreach (var recommendation in Model.Recommendations)
                    {
                        <article class="recommendation-card">
                            <div class="recommendation-head">
                                <strong>@recommendation.Title</strong>
                                <span>@recommendation.Priority</span>
                            </div>
                            <p>@recommendation.Description</p>
                            <small>@recommendation.ImpactText</small>
                        </article>
                    }
                }
            </div>
        </div>

        <div class="panel-block notices-panel" data-notices-panel>
            <div class="panel-head">
                <div>
                    <p class="panel-kicker">Диагностика расчета</p>
                    <h2>Сообщения и замечания</h2>
                </div>
                <button type="button"
                        class="btn btn-outline-primary btn-sm recommendation-toggle"
                        data-notices-toggle
                        aria-expanded="true">
                    Скрыть
                </button>
            </div>

            <ul class="notice-list" data-notices-content>
                @if (Model.Notices.Count == 0)
                {
                    <li class="muted-text">Дополнительных замечаний по расчету нет.</li>
                }
                else
                {
                    foreach (var notice in Model.Notices)
                    {
                        <li>@notice</li>
                    }
                }
            </ul>
        </div>
    </section>
</div>

<script>
    window.currentCalculationSavePayload = @Html.Raw(JsonConvert.SerializeObject(new
    {
        name = Model.CalculationName,
        calculationId = Model.SavedCalculationId,
        repeat = false,
        isTemplate = false,
        model = Model.Input
    }));
</script>
