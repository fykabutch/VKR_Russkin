@model TeploenergetikaKursovaya.Models.CalcViewModel
@{
    ViewData["Title"] = "Расчет потерь давления";
}

<div class="container mt-5">
    <h1 class="text-center mb-4">Расчет параметров дымовой трассы</h1>

    <form asp-action="Index" method="post" class="row g-3">
        <div class="col-md-6">
            <label asp-for="TgasInitial" class="form-label">Начальная температура газа (°C)</label>
            <input asp-for="TgasInitial" class="form-control">
            <span asp-validation-for="TgasInitial" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="TemperatureLossPerMeter" class="form-label">Потери температуры на 1 м (°C/м)</label>
            <input asp-for="TemperatureLossPerMeter" class="form-control">
            <span asp-validation-for="TemperatureLossPerMeter" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="GasFlowRate" class="form-label">Объемный расход газа (м³/с)</label>
            <input asp-for="GasFlowRate" class="form-control">
            <span asp-validation-for="GasFlowRate" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="SectionLength" class="form-label">Длина участка (м)</label>
            <input asp-for="SectionLength" class="form-control">
            <span asp-validation-for="SectionLength" class="text-danger"></span>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Рассчитать</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}