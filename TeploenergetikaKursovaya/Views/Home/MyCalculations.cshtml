@model TeploenergetikaKursovaya.Models.MyCalculationsViewModel
@{
    ViewData["Title"] = "Мои расчеты";
}

<div class="designer-shell">
    <section class="panel-block">
        <div class="panel-head panel-head-wrap">
            <div>
                <p class="panel-kicker">Профиль @Model.UserLogin</p>
                <h2>Мои расчеты</h2>
            </div>
            <a class="btn btn-outline-primary" href="@Url.Action("Calc")">Новый расчет</a>
        </div>

        <form class="calculation-filter-bar" method="get" action="@Url.Action("MyCalculations")">
            <div class="calculation-filter-field">
                <label for="calculationSearch">Поиск</label>
                <input id="calculationSearch" class="form-control" type="search" name="search" value="@Model.Search" placeholder="Название расчета" />
            </div>
            <div class="calculation-filter-field">
                <label for="templateFilter">Тип</label>
                <select id="templateFilter" class="form-select" name="templateFilter">
                    <option value="all" selected="@(Model.TemplateFilter == "all")">Все</option>
                    <option value="templates" selected="@(Model.TemplateFilter == "templates")">Только шаблоны</option>
                    <option value="regular" selected="@(Model.TemplateFilter == "regular")">Только расчеты</option>
                </select>
            </div>
            <div class="calculation-filter-field">
                <label for="calculationSort">Сортировка</label>
                <select id="calculationSort" class="form-select" name="sort">
                    <option value="updated_desc" selected="@(Model.Sort == "updated_desc")">Сначала обновленные</option>
                    <option value="updated_asc" selected="@(Model.Sort == "updated_asc")">Сначала давно обновленные</option>
                    <option value="created_desc" selected="@(Model.Sort == "created_desc")">Сначала новые</option>
                    <option value="created_asc" selected="@(Model.Sort == "created_asc")">Сначала старые</option>
                    <option value="name_asc" selected="@(Model.Sort == "name_asc")">Название А-Я</option>
                    <option value="name_desc" selected="@(Model.Sort == "name_desc")">Название Я-А</option>
                    <option value="pressure_desc" selected="@(Model.Sort == "pressure_desc")">Потери по убыванию</option>
                    <option value="pressure_asc" selected="@(Model.Sort == "pressure_asc")">Потери по возрастанию</option>
                </select>
            </div>
            <div class="calculation-filter-actions">
                <button class="btn btn-primary" type="submit">Показать</button>
                <a class="btn btn-outline-primary" href="@Url.Action("MyCalculations")">Сбросить</a>
            </div>
        </form>

        @if (Model.Calculations.Count == 0)
        {
            <p class="muted-text">
                @(Model.HasActiveFilters ? "По выбранным фильтрам расчеты не найдены." : "Сохраненных расчетов пока нет.")
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table modern-table">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Создан</th>
                            <th>Обновлен</th>
                            <th>Итог, Па</th>
                            <th>Шаблон</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var calculation in Model.Calculations)
                        {
                            <tr>
                                <td>
                                    <form class="calculation-name-form" method="post" action="@Url.Action("RenameCalculation", new { id = calculation.Id })">
                                        <input type="hidden" name="search" value="@Model.Search" />
                                        <input type="hidden" name="templateFilter" value="@Model.TemplateFilter" />
                                        <input type="hidden" name="sort" value="@Model.Sort" />
                                        <input class="form-control form-control-sm" name="name" value="@calculation.Name" maxlength="160" aria-label="Название расчета" />
                                        <button class="btn btn-outline-primary btn-sm" type="submit">Сохранить</button>
                                    </form>
                                </td>
                                <td>@calculation.CreatedAtLocal.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@calculation.UpdatedAtLocal.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@calculation.TotalPressureDrop.ToString("F2")</td>
                                <td>@(calculation.IsTemplate ? "Да" : "Нет")</td>
                                <td>
                                    <div class="my-calculations-actions">
                                        <a class="btn btn-outline-primary btn-sm" href="@Url.Action("CalculationResult", new { id = calculation.Id })">Результат</a>
                                        <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Calc", new { calculationId = calculation.Id })">Изменить</a>
                                        <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Calc", new { repeatCalculationId = calculation.Id })">Повторить</a>
                                        <form method="post" action="@Url.Action("ToggleCalculationTemplate", new { id = calculation.Id })">
                                            <input type="hidden" name="search" value="@Model.Search" />
                                            <input type="hidden" name="templateFilter" value="@Model.TemplateFilter" />
                                            <input type="hidden" name="sort" value="@Model.Sort" />
                                            <button class="btn btn-sm @(calculation.IsTemplate ? "btn-primary" : "btn-outline-primary")" type="submit">
                                                @(calculation.IsTemplate ? "Убрать шаблон" : "Сделать шаблоном")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
